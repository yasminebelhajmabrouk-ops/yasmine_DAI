@startuml
title DAI — Activity Diagram (Workflow global patient)

start

:Création / sélection patient;
:Création dossier anesthésique;

partition "Pré-op" {
  :Patient remplit questionnaire;
  :Enregistrement réponses;
  :Calcul automatique scores;
  :Validation / correction par anesthésiste;
}

partition "Per-op (Bloc)" {
  :Transition case -> PER_OP;
  :Démarrer session per-op;
  :Acquisition constantes;
  :Enregistrement événements / médicaments;
  if (Anomalie détectée ?) then (Oui)
    :Déclencher alerte;
    :Acquittement + commentaire;
  else (Non)
    :Continuer monitoring;
  endif
  :Fin session bloc;
}

partition "Post-op (SSPI)" {
  :Transition case -> POST_OP;
  :Démarrer séjour SSPI;
  :Saisir observation postop;
  :Évaluer douleur;
  :Calculer score Aldrete;
  if (Aldrete >= 9 ?) then (Oui)
    :READY_FOR_DISCHARGE;
  else (Non)
    :Poursuivre surveillance;
  endif
  :Fin séjour SSPI;
}

:Générer rapport anesthésie;
:Archiver et rendre consultable;
stop
@enduml