@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title DAI — C4 System Context Diagram

Person(patient, "Patient", "Remplit le questionnaire pré-opératoire")
Person(anesthesiste, "Anesthésiste", "Consulte, valide, décide")
Person(iade, "IADE", "Suit le patient au bloc et saisit événements / médicaments")
Person(sspi, "Équipe SSPI", "Assure le suivi post-opératoire et la sortie SSPI")
Person(admin, "Administrateur IT", "Gère utilisateurs, rôles et paramètres")

System(dai, "DAI", "Dossier d’Anesthésie Intelligent couvrant le parcours pré-op, per-op et post-op")

System_Ext(sih, "SIH / DPI", "Système d'information hospitalier / dossier patient informatisé")
System_Ext(devices, "Dispositifs biomédicaux", "Moniteurs et équipements envoyant les constantes vitales")
System_Ext(ai, "Services IA", "Calcul de scores, recommandations, assistance")
System_Ext(auth, "Service d’authentification", "OIDC / JWT / SSO")

Rel(patient, dai, "Remplit le questionnaire pré-op")
Rel(anesthesiste, dai, "Consulte le dossier, valide et prend des décisions")
Rel(iade, dai, "Suit le per-op et enregistre événements")
Rel(sspi, dai, "Suit le post-op et calcule la sortie")
Rel(admin, dai, "Administre la plateforme")

Rel(dai, sih, "Lit / échange données patient et documents", "REST / HL7 / FHIR")
Rel(devices, dai, "Alimente le dossier en constantes", "Gateway / protocole biomédical")
Rel(dai, ai, "Appelle services d’aide à la décision", "API")
Rel(dai, auth, "Authentifie les utilisateurs", "OIDC / JWT")

@enduml