@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title DAI — C4 Component Diagram (Backend Django)

Container_Boundary(api, "Backend API - Django") {

  Component(authComp, "Authentication Module", "Django auth / JWT / OIDC", "Gère authentification, autorisation et contrôle d'accès")
  Component(patientComp, "Patient Module", "Django App", "Gère identité patient")
  Component(caseComp, "Case Module", "Django App", "Gère le dossier anesthésique et les transitions d'état")
  Component(preopComp, "Pre-op Module", "Django App", "Gère questionnaire pré-op, réponses, bulk save, scores et validation")
  Component(peropComp, "Per-op Module", "Django App", "Gère session bloc, constantes, événements et médicaments")
  Component(postopComp, "Post-op Module", "Django App", "Gère séjour SSPI, observations, douleur et score Aldrete")
  Component(alertComp, "Alert Module", "Django App", "Détecte anomalies et suit le cycle de vie des alertes")
  Component(reportComp, "Report Module", "Django App", "Génère les rapports anesthésiques")
  Component(settingsComp, "Settings Module", "Django App", "Gère seuils, protocoles et templates")
  Component(auditComp, "Audit Module", "Django App", "Trace les actions critiques")
  Component(integrationComp, "Integration Module", "Django App", "Dialogue avec SIH, IA et gateway biomédicale")
  Component(repoComp, "Persistence Layer", "Django ORM", "Accès aux données PostgreSQL")
}

ContainerDb(db, "PostgreSQL", "Database", "Données métier et audit")
System_Ext(ai, "Service IA", "Calcul scores, recommandations")
System_Ext(sih, "SIH / DPI", "Données patient / documents")
System_Ext(gateway, "Device Gateway", "Flux biomédicaux")

Rel(authComp, patientComp, "Protège l'accès")
Rel(authComp, caseComp, "Protège l'accès")
Rel(authComp, preopComp, "Protège l'accès")
Rel(authComp, peropComp, "Protège l'accès")
Rel(authComp, postopComp, "Protège l'accès")

Rel(patientComp, repoComp, "Lit / écrit")
Rel(caseComp, repoComp, "Lit / écrit")
Rel(preopComp, repoComp, "Lit / écrit")
Rel(peropComp, repoComp, "Lit / écrit")
Rel(postopComp, repoComp, "Lit / écrit")
Rel(alertComp, repoComp, "Lit / écrit")
Rel(reportComp, repoComp, "Lit / écrit")
Rel(settingsComp, repoComp, "Lit / écrit")
Rel(auditComp, repoComp, "Lit / écrit")
Rel(integrationComp, repoComp, "Lit / écrit")

Rel(caseComp, patientComp, "Rattache dossier à patient")
Rel(preopComp, caseComp, "Utilise dossier anesthésique")
Rel(peropComp, caseComp, "Utilise dossier anesthésique")
Rel(postopComp, caseComp, "Utilise dossier anesthésique")
Rel(alertComp, caseComp, "Lie alertes au dossier")
Rel(reportComp, caseComp, "Génère synthèse à partir du dossier")

Rel(preopComp, ai, "Appelle scores / assistance", "REST")
Rel(integrationComp, sih, "Échange données", "REST / HL7 / FHIR")
Rel(integrationComp, gateway, "Reçoit constantes", "REST / messaging")
Rel(alertComp, peropComp, "Analyse constantes / événements")
Rel(reportComp, patientComp, "Utilise données patient")
Rel(repoComp, db, "Stocke / lit", "SQL")

@enduml